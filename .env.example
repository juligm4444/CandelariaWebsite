# Frontend API configuration
# Local development backend origin, without trailing slash
# In Vercel production, set VITE_API_ORIGIN=https://candelaria.website
VITE_API_ORIGIN=http://localhost:8000

# Supabase frontend configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend media storage can reuse the same project URL.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=media

# Payment public key for browser-side gateway SDK (never put secret keys here)
VITE_PAYMENT_PUBLIC_KEY=pk_test_replace_me

# -----------------------------------------------------------------------------
# Backend (Django) environment variables
# Copy these keys into backend/.env for backend runtime.
# -----------------------------------------------------------------------------

# Database Configuration
DB_NAME=candelaria_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=

# Optional full connection string (overrides DB_* if present)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

# Django core
SECRET_KEY=replace_with_a_secure_secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Frontend URL + CORS
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting
THROTTLE_ANON_RATE=120/hour
THROTTLE_USER_RATE=1000/hour
THROTTLE_BURST_RATE=60/minute
THROTTLE_AUTH_RATE=10/minute

# Upload limits
DATA_UPLOAD_MAX_MEMORY_SIZE=2097152
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880

# Login brute-force protection
AUTH_MAX_ATTEMPTS=8
AUTH_ATTEMPT_WINDOW_SECONDS=900

# Email settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@candelaria.local

# Payment gateway configuration
PAYMENT_PROVIDER=stripe
PAYMENT_PUBLIC_KEY=pk_test_replace_me
PAYMENT_SECRET_KEY=sk_test_replace_me
PAYMENT_WEBHOOK_SECRET=whsec_replace_me
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
PAYMENT_DEFAULT_CURRENCY=usd
PAYMENT_MIN_AMOUNT_CENTS=100
PAYMENT_MAX_AMOUNT_CENTS=5000000
PURCHASES_ENABLED=False

# PayU (if PAYMENT_PROVIDER=payu)
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_API_KEY=
PAYU_API_LOGIN=
PAYU_TEST_MODE=True

# -----------------------------------------------------------------------------
# Vercel production example values for candelaria.website
# Copy these into Vercel Environment Variables and replace placeholders.
# -----------------------------------------------------------------------------
# DEBUG=False
# ALLOWED_HOSTS=.vercel.app,candelaria.website,www.candelaria.website
# FRONTEND_URL=https://candelaria.website
# CORS_ALLOWED_ORIGINS=https://candelaria.website,https://www.candelaria.website
# CSRF_TRUSTED_ORIGINS=https://candelaria.website,https://www.candelaria.website
# PAYMENT_PROVIDER=payu
# PURCHASES_ENABLED=False
# PAYU_TEST_MODE=False
# SUPABASE_URL=https://thlhtuktznnlvxytbapa.supabase.co
# SUPABASE_STORAGE_BUCKET=media

# Team Leader Security Configuration
TEAM_LEADER_WHITELIST_ENABLED=true
TEAM_LEADER_AUTO_ASSIGN=false
ADMIN_APPROVAL_REQUIRED=true

# 🔒 SECURE TEAM LEADER WHITELISTS
# Add comma-separated emails (no spaces around commas)
# Only these emails can request team leadership
TEAM_LEADERS_EXECUTIVE_COMMITTEE=
TEAM_LEADERS_BATTERIES=
TEAM_LEADERS_CELLS=
TEAM_LEADERS_CHASSIS=
TEAM_LEADERS_LOGISTICS=
TEAM_LEADERS_DESIGN=j.galindom2@uniandes.edu.co
TEAM_LEADERS_HUMAN_RESOURCES=
TEAM_LEADERS_VALIDATION_TEAM=

# Security Logging
SECURITY_LOG_ENABLED=true
SECURITY_LOG_LEVEL=INFO
